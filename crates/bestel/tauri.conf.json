{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bestel",
  "version": "0.1.0",
  "identifier": "com.bestel.app",
  "build": {
    "beforeDevCommand": "npm --prefix ui run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --prefix ui run build",
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bestel",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "center": true,
        "transparent": false,
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}
