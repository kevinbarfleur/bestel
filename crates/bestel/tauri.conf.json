{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bestel",
  "version": "0.1.0",
  "identifier": "com.bestel.app",
  "build": {
    "beforeDevCommand": "npm --prefix ui run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --prefix ui run build",
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bestel",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "center": true,
        "transparent": false,
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Bestel — chronicler of Wraeclast. AI assistant for Path of Exile 1 & 2.",
    "longDescription": "Desktop AI companion for Path of Exile players. Reads your Path of Building exports, runs research against the wiki, and helps with build coaching. Offline-capable via Ollama; cloud LLMs (Anthropic, DeepSeek) supported via API keys."
  }
}
